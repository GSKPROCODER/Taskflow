# ─────────────────────────────────────────────────────────────────────────────
# TaskFlow environment variables. Copy to `.env.local` for local dev and add the
# same keys in your Vercel project settings for deployments. NEVER commit .env*.
# ─────────────────────────────────────────────────────────────────────────────

# ── Frontend (browser) — must be VITE_ prefixed; safe to expose publicly ──────
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-public-key

# ── Backend (Hono API / Vercel functions) — server-only secrets ──────────────
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-secret-key

# JWT secret for verifying Supabase tokens server-side (Supabase JWT secret)
SUPABASE_JWT_SECRET=your-supabase-jwt-secret
